generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum TestSuiteStatus {
  ACTIVE
  ARCHIVED
}

enum TestCaseStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum TestPriority {
  LOW
  MEDIUM
  HIGH
}

enum TestSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TestRunStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ABORTED
}

enum TestResultStatus {
  NOT_RUN
  PASSED
  FAILED
  BLOCKED
  SKIPPED
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  key         String        @unique
  description String        @default("")
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  suites       TestSuite[]
  testRuns     TestRun[]
  requirements Requirement[]

  @@index([deletedAt])
  @@map("projects")
}

model TestSuite {
  id          String          @id @default(uuid()) @db.Uuid
  projectId   String          @db.Uuid
  name        String
  description String          @default("")
  status      TestSuiteStatus @default(ACTIVE)
  position    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCase[]
  testRuns  TestRun[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([deletedAt])
  @@map("test_suites")
}

model TestCase {
  id             String         @id @default(uuid()) @db.Uuid
  suiteId        String         @db.Uuid
  clonedFromId   String?        @db.Uuid
  title          String
  description    String         @default("")
  preconditions  String         @default("")
  expectedResult String         @default("")
  status         TestCaseStatus @default(DRAFT)
  priority       TestPriority   @default(MEDIUM)
  severity       TestSeverity   @default(MEDIUM)
  version        Int            @default(1)
  tags           String[]       @default([])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  suite        TestSuite     @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  clonedFrom   TestCase?     @relation("ClonedTestCases", fields: [clonedFromId], references: [id], onDelete: SetNull)
  clones       TestCase[]    @relation("ClonedTestCases")
  steps        TestStep[]
  results      TestResult[]
  requirements Requirement[]

  @@index([suiteId])
  @@index([status])
  @@index([priority])
  @@index([deletedAt])
  @@map("test_cases")
}

model TestStep {
  id             String    @id @default(uuid()) @db.Uuid
  testCaseId     String    @db.Uuid
  position       Int
  action         String
  expectedResult String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, position])
  @@index([testCaseId])
  @@index([deletedAt])
  @@map("test_steps")
}

model TestRun {
  id          String        @id @default(uuid()) @db.Uuid
  projectId   String        @db.Uuid
  suiteId     String?       @db.Uuid
  createdById String?       @db.Uuid
  name        String
  description String        @default("")
  status      TestRunStatus @default(PLANNED)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suite     TestSuite?   @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  createdBy User?        @relation("CreatedTestRuns", fields: [createdById], references: [id], onDelete: SetNull)
  results   TestResult[]

  @@index([projectId])
  @@index([suiteId])
  @@index([status])
  @@map("test_runs")
}

model TestResult {
  id              String           @id @default(uuid()) @db.Uuid
  testRunId       String           @db.Uuid
  testCaseId      String           @db.Uuid
  executedById    String?          @db.Uuid
  status          TestResultStatus @default(NOT_RUN)
  notes           String           @default("")
  actualResult    String           @default("")
  defectReference String           @default("")
  executedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  testRun    TestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  executedBy User?    @relation("ExecutedResults", fields: [executedById], references: [id], onDelete: SetNull)

  @@unique([testRunId, testCaseId])
  @@index([testCaseId])
  @@index([status])
  @@map("test_results")
}

model User {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  email     String     @unique
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  createdTestRuns TestRun[]    @relation("CreatedTestRuns")
  executedResults TestResult[] @relation("ExecutedResults")

  @@index([deletedAt])
  @@map("users")
}

model Requirement {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  referenceKey String
  title        String
  description  String   @default("")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCase[]

  @@unique([projectId, referenceKey])
  @@index([projectId])
  @@map("requirements")
}
