generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum TestSuiteStatus {
  ACTIVE
  ARCHIVED
}

enum TestCaseStatus {
  ACTIVE
  ARCHIVED
}

enum TestPriority {
  LOW
  MEDIUM
  HIGH
}

enum TestSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TestRunStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TestRunTestType {
  SMOKE
  FUNCIONAL
  REGRESSAO
  ROBUSTEZ
}

enum TestResultStatus {
  PENDING
  PASSED
  FAILED
  SKIPPED
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  ADMIN
  QA
  VIEWER
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  key         String        @unique
  description String        @default("")
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  suites       TestSuite[]
  testPlans    TestPlan[]
  testRuns     TestRun[]
  requirements Requirement[]

  @@index([deletedAt])
  @@map("projects")
}

model TestSuite {
  id          String          @id @default(uuid()) @db.Uuid
  projectId   String          @db.Uuid
  name        String
  description String          @default("")
  status      TestSuiteStatus @default(ACTIVE)
  position    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCase[]
  testRuns  TestRunSuite[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([deletedAt])
  @@map("test_suites")
}

model TestCase {
  id             String         @id @default(uuid()) @db.Uuid
  suiteId        String         @db.Uuid
  clonedFromId   String?        @db.Uuid
  title          String
  description    String         @default("")
  preconditions  String         @default("")
  expectedResult String         @default("")
  status         TestCaseStatus @default(ACTIVE)
  priority       TestPriority   @default(MEDIUM)
  severity       TestSeverity   @default(MEDIUM)
  version        Int            @default(1)
  tags           String[]       @default([])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  suite        TestSuite     @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  clonedFrom   TestCase?     @relation("ClonedTestCases", fields: [clonedFromId], references: [id], onDelete: SetNull)
  clones       TestCase[]    @relation("ClonedTestCases")
  steps        TestStep[]
  results      TestResult[]
  requirements Requirement[]

  @@index([suiteId])
  @@index([status])
  @@index([priority])
  @@index([deletedAt])
  @@map("test_cases")
}

model TestStep {
  id             String    @id @default(uuid()) @db.Uuid
  testCaseId     String    @db.Uuid
  order          Int
  description    String
  expectedResult String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, order])
  @@index([testCaseId])
  @@index([deletedAt])
  @@map("test_steps")
}

model TestPlan {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @db.Uuid
  name        String
  version     String
  description String    @default("")
  sections    Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testRuns TestRun[]

  @@unique([projectId, name, version])
  @@index([projectId])
  @@index([deletedAt])
  @@map("test_plans")
}

model TestRun {
  id           String        @id @default(uuid()) @db.Uuid
  projectId    String        @db.Uuid
  testPlanId   String        @db.Uuid
  createdById  String?       @db.Uuid
  assignedToId String        @db.Uuid
  name         String
  description  String        @default("")
  status       TestRunStatus @default(PENDING)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testPlan   TestPlan       @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  createdBy  User?          @relation("CreatedTestRuns", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo User           @relation("AssignedTestRuns", fields: [assignedToId], references: [id], onDelete: Restrict)
  suites     TestRunSuite[]
  results    TestResult[]

  @@index([projectId])
  @@index([testPlanId])
  @@index([assignedToId])
  @@index([status])
  @@index([deletedAt])
  @@map("test_runs")
}

model TestRunSuite {
  id          String   @id @default(uuid()) @db.Uuid
  testRunId   String   @db.Uuid
  testSuiteId String   @db.Uuid
  testType    TestRunTestType @default(FUNCIONAL)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  testRun   TestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testSuite TestSuite @relation(fields: [testSuiteId], references: [id], onDelete: Cascade)

  @@unique([testRunId, testSuiteId])
  @@index([testType])
  @@index([testSuiteId])
  @@map("test_run_suites")
}

model TestResult {
  id           String           @id @default(uuid()) @db.Uuid
  testRunId    String           @db.Uuid
  testCaseId   String           @db.Uuid
  executedById String?          @db.Uuid
  status       TestResultStatus @default(PENDING)
  comment      String           @default("")
  attachments  String[]         @default([])
  executedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  testRun    TestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  executedBy User?    @relation("ExecutedResults", fields: [executedById], references: [id], onDelete: SetNull)

  @@unique([testRunId, testCaseId])
  @@index([testCaseId])
  @@index([status])
  @@map("test_results")
}

model User {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  email     String     @unique
  password  String
  role      UserRole   @default(QA)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  assignedTestRuns TestRun[]    @relation("AssignedTestRuns")
  createdTestRuns  TestRun[]    @relation("CreatedTestRuns")
  executedResults  TestResult[] @relation("ExecutedResults")

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Requirement {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  referenceKey String
  title        String
  description  String   @default("")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCase[]

  @@unique([projectId, referenceKey])
  @@index([projectId])
  @@map("requirements")
}
