NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://qa_user:qa_pass@localhost:5432/qa_platform"

JWT_SECRET="replace-this-with-at-least-32-random-characters"
JWT_EXPIRES_IN="15m"

FRONTEND_URL="http://localhost:5173"

MAIL_FROM="QA Platform <no-reply@example.com>"
FIRST_ACCESS_TOKEN_EXPIRES_IN_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRES_IN_MINUTES=30

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=""
OPENROUTER_ENDPOINT="https://openrouter.ai/api/v1/chat/completions"
OPENROUTER_MODEL="openrouter/openrouter/free"
OPENROUTER_HTTP_REFERER="http://localhost:5173"
OPENROUTER_TITLE="QA Platform"
TEMPERATURE=0.2
MAX_TOKENS=4096
TIMEOUT=120
LLM_RETRIES=3
LLM_STREAMING=false

SHORTCUT_API_TOKEN=""
SHORTCUT_API_URL="https://api.app.shortcut.com/api/v3"
SHORTCUT_SPACE_ID=""
SHORTCUT_PROJECT_ID=""
SHORTCUT_WORKFLOW_STATE_ID=""
SHORTCUT_TEAM_ID=""

SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_HELO_NAME="qa-platform.local"
SMTP_TIMEOUT_MS=10000
SMTP_USER=""
SMTP_PASSWORD=""
